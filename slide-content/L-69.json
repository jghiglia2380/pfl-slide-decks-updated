    {
      "number": 4,
      "type": "content",
      "headerColor": "indigo",
      "content": {
        "headerTitle": "What Are Alternative Investments?",
        "layout": "concept-full",
        "layoutData": {
          "title": "Asset classes beyond traditional stocks and bonds that offer different risk/return profiles",
          "bulletPoints": [
            "<strong>\ud83c\udfe0 Real Estate:</strong> Property ownership & REITs",
            "<strong>\ud83e\udd47 Precious Metals:</strong> Gold, silver, platinum",
            "<strong>\ud83d\udee2\ufe0f Commodities:</strong> Oil, natural gas, agriculture",
            "<strong>\u20bf Cryptocurrency:</strong> Bitcoin, Ethereum, digital assets"
          ],
          "keyPoint": "Alternatives aren't better or worse\u2014they're <em>different</em>. They often move independently from traditional markets, providing diversification benefits."
        }
      }
    },
    {
      "number": 5,
      "type": "content",
      "headerColor": "amber",
      "content": {
        "headerTitle": "Key Vocabulary: Correlation & Liquidity",
        "layout": "comparison-grid",
        "layoutData": {
          "leftColumn": {
            "icon": "\ud83d\udcca",
            "title": "Correlation",
            "items": [
              "How closely two investments move together (-1.0 to +1.0)",
              "<strong>+1.0:</strong> Move in perfect sync",
              "<strong>0:</strong> No relationship",
              "<strong>-1.0:</strong> Move in opposite directions",
              "",
              "<strong>Example:</strong> During 2020 crash, stocks fell 30% while gold rose 25%"
            ]
          },
          "rightColumn": {
            "icon": "\ud83d\udca7",
            "title": "Liquidity",
            "items": [
              "How quickly you can sell without losing value",
              "",
              "<strong>Stocks:</strong> Instant (seconds)",
              "<strong>REITs:</strong> Instant (like stocks)",
              "<strong>Gold:</strong> Days",
              "<strong>Real Estate:</strong> Months",
              "<strong>Private Equity:</strong> Years"
            ]
          }
        }
      }
    },
    {
      "number": 6,
      "type": "content",
      "headerColor": "green",
      "content": {
        "headerTitle": "Key Vocabulary: REIT & Inflation Hedge",
        "layout": "comparison-grid",
        "layoutData": {
          "leftColumn": {
            "icon": "\ud83c\udfe2",
            "title": "REIT (Real Estate Investment Trust)",
            "items": [
              "A company that owns and operates income-producing real estate",
              "",
              "\u2022 Allows real estate investing without buying property",
              "\u2022 Must distribute 90% of income as dividends",
              "\u2022 Buy/sell like regular stocks",
              "\u2022 Start with as little as $100"
            ]
          },
          "rightColumn": {
            "icon": "\ud83d\udee1\ufe0f",
            "title": "Inflation Hedge",
            "items": [
              "Investment expected to maintain/increase value when prices rise",
              "",
              "<strong>Good Hedges:</strong>",
              "\u2705 Real estate (rents rise)",
              "\u2705 Gold (limited supply)",
              "\u2705 Commodities (actual goods)",
              "",
              "<strong>Poor Hedge:</strong>",
              "\u274c Bonds (fixed payments worth less)"
            ]
          }
        }
      }
    },
    {
