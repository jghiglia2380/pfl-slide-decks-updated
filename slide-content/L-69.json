      "type": "content",
      "headerColor": "indigo",
      "content": {
        "headerTitle": "Real Estate: Two Paths",
        "layout": "balanced-layout",
        "layoutData": {
          "leftPanel": {
            "title": "Comparison Table",
            "paragraphs": [
              "<strong>Initial Capital</strong>",
              "\u2022 Direct Property: $40K-$80K down payment",
              "\u2022 REIT Investment: $100-$1,000 (any amount)",
              "",
              "<strong>Management</strong>",
              "\u2022 Direct Property: Active (repairs, tenants)",
              "\u2022 REIT Investment: Passive (professional)",
              "",
              "<strong>Liquidity</strong>",
              "\u2022 Direct Property: Very low (months to sell)",
              "\u2022 REIT Investment: High (sell instantly)"
            ]
          },
          "rightPanel": {
            "stats": [],
            "infoCard": {
              "title": "Additional Factors",
              "color": "teal",
              "items": [
                "<strong>Diversification</strong>",
                "\u2022 Direct Property: Single property risk",
                "\u2022 REIT Investment: Hundreds of properties",
                "",
                "<strong>Income</strong>",
                "\u2022 Direct Property: Rent (if occupied)",
                "\u2022 REIT Investment: Dividends (quarterly)",
                "",
                "<strong>Control</strong>",
                "\u2022 Direct Property: Full control",
                "\u2022 REIT Investment: None (trust management)"
              ]
            }
          }
        }
      }
    },
    {
