    },
    {
      "number": 16,
      "type": "content",
      "headerColor": "rose",
      "content": {
        "headerTitle": "Case Study: Alex's Crypto Lesson",
        "layout": "scenario-layout",
        "layoutData": {
          "scenario": {
            "icon": "\ud83d\ude30",
            "name": "Alex - What Went Wrong (Age 22)",
            "paragraphs": [
              "\u274c Invested <strong>entire savings</strong> ($8,000)",
              "\u274c Didn't understand the asset",
              "\u274c Bought at market peak (FOMO)",
              "\u274c No emergency fund",
              "\u274c Panic sold at bottom",
              "",
              "<strong>The True Cost:</strong>",
              "\u2022 Principal lost: $5,600",
              "\u2022 Opportunity cost: That $8K at age 22 in S&P 500 would become <strong>$123,000</strong> at age 65 (7% annual return)"
