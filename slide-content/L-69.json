              "\u2022 $10K emergency fund \u2713",
              "\u2022 15% to 401(k) & Roth IRA \u2713",
              "\u2022 Core: Low-cost index funds \u2713",
              "",
              "<strong>Alternative Allocation:</strong>",
              "\u2022 5% REIT index fund ($800)",
              "\u2022 3% Gold ETF ($500)",
              "\u2022 2% Crypto ($300) - \"could lose it all\"",
              "",
              "<strong>Jordan's Rules:</strong>",
              "\u2022 Never add more until alternatives fall below target %",
              "\u2022 Rebalance annually\u2014take profits from winners",
              "\u2022 Never touch core portfolio to chase trends"
            ]
          },
          "outcomes": [
            {
              "type": "after",
              "label": "5-Year Result",
              "value": "$42K",
              "detail": "Portfolio grew from $15K \u2192 $42K. Crypto swung wildly ($300 \u2192 $2,400 \u2192 $600), but core portfolio provided stability."
            }
          ]
        }
